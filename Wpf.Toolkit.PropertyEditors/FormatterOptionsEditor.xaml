<UserControl x:Class="Wpf.Toolkit.PropertyEditors.FormatterOptionsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="400"
             x:Name="editorRoot">
    <Grid Margin="0">
        <DataGrid ItemsSource="{Binding Value, ElementName=editorRoot}"
                  AutoGenerateColumns="False" ColumnHeaderHeight="0"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False" BorderBrush="Transparent" BorderThickness="0"
                  HeadersVisibility="Column"                  
                  HorizontalGridLinesBrush="LightGray"
                  VerticalGridLinesBrush="LightGray"
                  MinHeight="100"
                  VerticalAlignment="Top">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"
                                    Width="*"
                                    Binding="{Binding Name, Mode=OneWay}" 
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="Wert"
                                    Width="2*"
                                    Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

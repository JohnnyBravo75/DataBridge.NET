<wpfControls:WPFUserControl
    x:Class="DataBridge.GUI.UserControls.DataCommandControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Converters="clr-namespace:DataBridge.GUI.Converters;assembly=DataBridge.WPFBase"
    xmlns:local="clr-namespace:DataBridge.GUI.Converters"
    xmlns:wpfControls="clr-namespace:DataBridge.GUI.Core.View.WPFControls;assembly=DataBridge.WPFBase"
    xmlns:wpfToolkit="http://schemas.xceed.com/wpf/xaml/toolkit"
    xmlns:userControls="clr-namespace:DataBridge.GUI.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="300" d:DesignWidth="300">

    <wpfControls:WPFUserControl.Resources>
        <Converters:NullImageConverter x:Key="NullImageConverter" />
        <Converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Converters:ObjectToVisibilityConverter x:Key="ObjectToVisibilityConverter" />
        <local:ValidationStatusToBrushConverter x:Key="ValidationStatusToBrushConverter" />
        <local:ValidationStatusToTooltipConverter x:Key="ValidationStatusToTooltipConverter" />
        <local:CommandsToStepsConverter x:Key="CommandsToStepsConverter" />
    </wpfControls:WPFUserControl.Resources>

    <Grid x:Name="LayoutRoot" Margin="15,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--****Row 0: Title bar****-->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="{Binding Image, Converter={StaticResource NullImageConverter}}" Width="Auto" Height="24" Margin="0,0,2,0" />
            <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="16" FontWeight="Bold" />
            <Ellipse Grid.Column="2" Width="12" Height="12" Margin="4,0" VerticalAlignment="Center"
                     Fill="{Binding ValidationMessages, RelativeSource={RelativeSource AncestorType=userControls:DataCommandControl}, Converter={StaticResource ValidationStatusToBrushConverter}}"
                     ToolTip="{Binding ValidationMessages, RelativeSource={RelativeSource AncestorType=userControls:DataCommandControl}, Converter={StaticResource ValidationStatusToTooltipConverter}}" />
            <Button Grid.Column="3" Content="&#x2715;" Foreground="Red" FontWeight="Bold"
                    Padding="6,2" Margin="4,0,0,0" ToolTip="Schritt l&#xF6;schen"
                    Click="btnDelete_Click" />
        </Grid>

        <!--****Row 1: PropertyGrid****-->
        <wpfToolkit:PropertyGrid Grid.Row="1" HorizontalAlignment="Left" Width="400" x:Name="PropertyGrid"
                                 AutoGenerateProperties="True" SelectedObject="{Binding}" Background="Transparent"
                                 ShowSearchBox="False" ShowAdvancedOptions="False" ShowSortOptions="False"
                                 ShowSummary="False" ShowTitle="False" ShowDescriptionByTooltip="True" ShowPreview="False" />

        <!--****Row 2: Add Sub-Step****-->
        <Button Grid.Row="2" Content="+ Unterschritt" HorizontalAlignment="Left" Margin="0,4" Padding="6,2"
                Click="btnAddSubStep_Click" />

        <!--****Row 3: Child Commands Expander****-->
        <Expander Grid.Row="3">
            <Expander.Header>
                <StackPanel Orientation="Horizontal"
                        Visibility="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Expander}}, Path=IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                    <TextBlock FontSize="14" FontWeight="Bold"><Run Text="{Binding Commands.Count, Mode=OneWay}" /><Run Text=" Unterschritte..." /></TextBlock>
                </StackPanel>
            </Expander.Header>
            <ItemsControl ItemsSource="{Binding Commands, Converter={StaticResource CommandsToStepsConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" x:Name="subStepPanel">
                            <userControls:ParameterBadgesControl
                                Parameters="{Binding Command.Parameters}"
                                DirectionFilter="In,InOut"
                                IsClickable="False"
                                Margin="15,4,0,0" />
                            <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="0,2,0,2">
                                <userControls:DataCommandControl DataContext="{Binding Command}"
                                    AvailableTokens="{Binding DataContext.AvailableTokens, RelativeSource={RelativeSource AncestorType=StackPanel}}" />
                            </Border>
                            <userControls:ParameterBadgesControl
                                Parameters="{Binding Command.Parameters}"
                                DirectionFilter="Out,InOut"
                                IsClickable="True"
                                Margin="15,0,0,4" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>
    </Grid>
</wpfControls:WPFUserControl>

<UserControl x:Class="DataBridge.GUI.UserControls.ParameterBadgesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:Converters="clr-namespace:DataBridge.GUI.Converters;assembly=DataBridge.WPFBase"
             xmlns:local="clr-namespace:DataBridge.GUI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="28" d:DesignWidth="500"
             x:Name="badgesRoot">

    <UserControl.Resources>
        <local:DirectionToColorConverter x:Key="DirectionToColorConverter" />
        <Converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Flat button style — used for all badges; cursor changes when clickable -->
        <Style x:Key="BadgeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{Binding Direction, Converter={StaticResource DirectionToColorConverter}}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="Margin" Value="2,1" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="3" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Horizontal list of parameter badges -->
    <ItemsControl ItemsSource="{Binding FilteredParameters, ElementName=badgesRoot}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Button Style="{StaticResource BadgeButtonStyle}"
                        Click="Badge_Click"
                        Tag="{Binding IsClickable, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <Button.IsEnabled>
                        <Binding Path="IsClickable" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                    </Button.IsEnabled>
                    <ToolTipService.ToolTip>
                        <ToolTip>
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="{Binding Name}" />
                                <TextBlock Text="{Binding Direction}" />
                                <TextBlock><Run Text="Typ: " /><Run Text="{Binding DataType}" /></TextBlock>
                                <TextBlock><Run Text="Pflichtfeld: " /><Run Text="{Binding NotNull}" /></TextBlock>
                                <TextBlock><Run Text="Token: {" /><Run Text="{Binding Token}" /><Run Text="}" /></TextBlock>
                                <TextBlock Text="▶ Klicken um {Token} zu kopieren"
                                           FontStyle="Italic" Foreground="#555"
                                           Visibility="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ToolTip}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </ToolTip>
                    </ToolTipService.ToolTip>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="White" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,2,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Direction}" Value="In"><Setter Property="Text" Value="→" /></DataTrigger>
                                        <DataTrigger Binding="{Binding Direction}" Value="Out"><Setter Property="Text" Value="←" /></DataTrigger>
                                        <DataTrigger Binding="{Binding Direction}" Value="InOut"><Setter Property="Text" Value="⇄" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="*" Foreground="Yellow" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"
                                   Visibility="{Binding NotNull, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Button>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>

            </Expander>
        </HierarchicalDataTemplate>-->
    </wpfControls:WPFUserControl.Resources>

    <!--**************RootGrid******************-->
    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="220" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <wpfControls:WPFComboBox x:Name ="cmbPipeline" HorizontalAlignment="Stretch" Margin="2" FontSize="16" FontWeight="Bold"
                                                    ItemsSource="{Binding CurrentDataBridgeInfo.PipelineInfos}"
                                                    DisplayMemberPath="Name"
                                                    SelectedItem="{Binding CurrentPipelineInfo, Mode=TwoWay, Converter={StaticResource DebugConverter}}" />

        <!-- Header-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88*" />
                <ColumnDefinition Width="27*"/>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
        </Grid>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <ItemsControl x:Name="lbCommands" ItemsSource="{Binding CurrentPipelineSteps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="0,2,0,5">
                            <StackPanel Orientation="Vertical" x:Name="stepPanel">
                                <!-- Der DataCommand-Editor -->
                                <userControls:DataCommandControl DataContext="{Binding Command}"
                                    AvailableTokens="{Binding DataContext.AvailableTokens, RelativeSource={RelativeSource AncestorType=StackPanel}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom toolbar -->
        <Grid Grid.Row="3" Margin="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="+ Schritt hinzufügen" Margin="2" Padding="8,3"
                        Command="{Binding AddStepCommand}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="4" Margin="2" Padding="4" BorderBrush="#CCCCCC" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Status:" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DebugStatusText}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Dauer:" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DebugDurationText}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="5" Margin="2">
            <TabItem Header="Logs">
                <ListView ItemsSource="{Binding DebugLogEntries}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Zeit" Width="150" DisplayMemberBinding="{Binding Timestamp}" />
                            <GridViewColumn Header="Level" Width="70" DisplayMemberBinding="{Binding Level}" />
                            <GridViewColumn Header="Quelle" Width="220" DisplayMemberBinding="{Binding Source}" />
                            <GridViewColumn Header="Nachricht" Width="480" DisplayMemberBinding="{Binding Message}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>

        <!-- Bottom toolbar -->
        <Grid Grid.Row="6" Margin="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="2" Content="Debug" Margin="2" Padding="8,3"
         Command="{Binding DebugCommand}" />
            <Button Grid.Column="3" Content="Stop" Margin="2" Padding="8,3"
         Command="{Binding CancelDebugCommand}" />
            <Button Grid.Column="1" Content="Speichern" Margin="2" Padding="8,3"
             Command="{Binding SavePipelineCommand}" />
            <Button Grid.Column="0" Content="XML öffnen" Margin="2" Padding="8,3"
              Command="{Binding OpenPipelineXmlCommand}" HorizontalAlignment="Left" />
        </Grid>
    </Grid>
</wpfControls:WPFUserControl>
            </Expander>
        </HierarchicalDataTemplate>-->
    </wpfControls:WPFUserControl.Resources>

    <!--**************RootGrid******************-->
    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <wpfControls:WPFComboBox x:Name ="cmbPipeline" HorizontalAlignment="Stretch" Margin="2" FontSize="16" FontWeight="Bold"
                                                    ItemsSource="{Binding CurrentDataBridgeInfo.PipelineInfos}"
                                                    DisplayMemberPath="Name"
                                                    SelectedItem="{Binding CurrentPipelineInfo, Mode=TwoWay, Converter={StaticResource DebugConverter}}" />

        <!-- Header-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88*" />
                <ColumnDefinition Width="27*"/>
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!--<wpfControls:WPFTitleText Grid.Column="0" Text="Pipeline" Grid.ColumnSpan="3" Margin="0,0,70,0" />
            <Button Grid.Column="2" Content="Speichern" Margin="2,2,2,2" Padding="6,2"
                    Command="{Binding SavePipelineCommand}" />-->
        </Grid>

        <!--<wpfControls:WPFTreeView Grid.Row="2" x:Name="treeCommands" Visibility="Collapsed"
                  ItemsSource="{Binding CurrentPipeline.Commands}"
                  ItemTemplate="{StaticResource Level1Template}"
                  CurrentItem="{Binding CurrentDataCommand, Mode=TwoWay}">
            <wpfControls:WPFTreeView.ItemContainerStyle>
                <Style TargetType="{x:Type TreeViewItem}">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                </Style>
            </wpfControls:WPFTreeView.ItemContainerStyle>
        </wpfControls:WPFTreeView>-->

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <ItemsControl x:Name="lbCommands" ItemsSource="{Binding CurrentPipelineSteps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Margin="0,0,0,20">
                            <StackPanel Orientation="Vertical" x:Name="stepPanel">
                                <!-- Der DataCommand-Editor -->
                                <userControls:DataCommandControl DataContext="{Binding Command}"
                                    AvailableTokens="{Binding DataContext.AvailableTokens, RelativeSource={RelativeSource AncestorType=StackPanel}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom toolbar -->
        <Grid Grid.Row="3" Margin="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="+ Schritt hinzufügen" Margin="2" Padding="8,3"
                        Command="{Binding AddStepCommand}" />
            </StackPanel>
            <Button Grid.Column="1" Content="Speichern" Margin="2" Padding="8,3"
                    Command="{Binding SavePipelineCommand}" />
        </Grid>
    </Grid>
</wpfControls:WPFUserControl>
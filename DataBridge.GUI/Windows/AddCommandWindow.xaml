<WPFControls:WPFWindow x:Class="DataBridge.GUI.Windows.AddCommandWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:WPFControls="clr-namespace:DataBridge.GUI.Core.View.WPFControls;assembly=DataBridge.WPFBase"
    xmlns:wpfToolkit="http://schemas.xceed.com/wpf/xaml/toolkit"
    Title="Schritt hinzufügen" Width="700" Height="550"
    WindowStartupLocation="CenterScreen">

    <!--**************Resources******************-->
    <WPFControls:WPFWindow.Resources>
    </WPFControls:WPFWindow.Resources>

    <!--**************RootGrid******************-->
    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="35" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: adapter list grouped by Group -->
            <DockPanel Grid.Column="0" Margin="4">
                <TextBlock DockPanel.Dock="Top" Text="Adapter wählen:" FontWeight="Bold" Margin="0,0,0,4" />
                <ListBox x:Name="lstCommands"
                         ItemsSource="{Binding AvailableCommands}"
                         SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                         DisplayMemberPath="Title"
                         SelectionChanged="lstCommands_SelectionChanged" />
            </DockPanel>

            <!-- Right: property editor for selected command -->
            <DockPanel Grid.Column="1" Margin="4">
                <TextBlock DockPanel.Dock="Top" Text="Parameter:" FontWeight="Bold" Margin="0,0,0,4" />
                <wpfToolkit:PropertyGrid x:Name="propertyGrid"
                                         SelectedObject="{Binding SelectedCommand}"
                                         AutoGenerateProperties="True"
                                         ShowSearchBox="False"
                                         ShowAdvancedOptions="False"
                                         ShowSortOptions="False"
                                         ShowSummary="True"
                                         ShowTitle="False"
                                         ShowDescriptionByTooltip="True"
                                         ShowPreview="False"
                                         Background="Transparent" />
            </DockPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,0,0,0">
            <WPFControls:WPFButton x:Name="btnOk" Content="Ok" Width="100" Height="25"
                                   Click="btnOk_Click" />
            <WPFControls:WPFButton x:Name="btnCancel" Content="Abbrechen" Width="100" Height="25"
                                   Click="btnCancel_Click" Margin="5,0,0,0" />
        </StackPanel>
    </Grid>
</WPFControls:WPFWindow>
